ion on the actual product packaging.\u003c\/span\u003e\u003c\/p\u003e","brand":"MADARA","offers":[{"title":"Default Title","offer_id":50916412555591,"sku":"","price":25.9,"currency_code":"EUR","in_stock":true}],"thumbnail_url":"\/\/cdn.shopify.com\/s\/files\/1\/0790\/6829\/9591\/files\/madara-peel-creamy-clay-aha-peel-mask-60ml-458560.jpg?v=1739897164","url":"https:\/\/bioskina.com\/products\/madara-peel-creamy-clay-aha-peel-mask-60ml","provider":"bioskina","version":"1.0","type":"link"}